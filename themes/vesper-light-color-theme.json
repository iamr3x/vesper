{
  "$schema": "vscode://schemas/color-theme",
  "name": "Vesper Light",
  "type": "light",
  "colors": {
    "editor.background": "#F5F0FF",
    "editor.foreground": "#2D2B55",
    "editorLineNumber.foreground": "#9e9cc0",
    "editorLineNumber.activeForeground": "#7B7A9E",
    "editor.selectionBackground": "#2563EB40",
    "editor.inactiveSelectionBackground": "#2563EB20",
    "editor.lineHighlightBackground": "#00000008",
    "editorCursor.foreground": "#2D2B55",
    "editorWhitespace.foreground": "#7B7A9E50",
    "editorIndentGuide.background1": "#D4CCF0",
    "editorIndentGuide.activeBackground1": "#7B7A9E",
    "editor.findMatchBackground": "#0891B250",
    "editor.findMatchHighlightBackground": "#0891B230",
    "editorBracketMatch.background": "#2563EB30",
    "editorBracketMatch.border": "#2563EB",
    "sideBar.background": "#E4DCFC",
    "sideBar.foreground": "#2D2B55",
    "sideBar.border": "#D4CCF0",
    "sideBarTitle.foreground": "#7B7A9E",
    "activityBar.background": "#E4DCFC",
    "activityBar.foreground": "#2D2B55",
    "activityBar.inactiveForeground": "#7B7A9E",
    "activityBar.border": "#D4CCF0",
    "statusBar.background": "#E4DCFC",
    "statusBar.foreground": "#2D2B55",
    "statusBar.border": "#D4CCF0",
    "titleBar.activeBackground": "#E4DCFC",
    "titleBar.activeForeground": "#2D2B55",
    "titleBar.border": "#D4CCF0",
    "tab.activeBackground": "#EDE8F8",
    "tab.inactiveBackground": "#F5F0FF",
    "tab.activeForeground": "#2D2B55",
    "tab.inactiveForeground": "#7B7A9E",
    "tab.border": "#D4CCF0",
    "panel.background": "#E4DCFC",
    "panel.border": "#D4CCF0",
    "terminal.background": "#E4DCFC",
    "terminal.foreground": "#2D2B55",
    "terminal.ansiBlack": "#EDE8F8",
    "terminal.ansiRed": "#BE185D",
    "terminal.ansiGreen": "#3D6B3D",
    "terminal.ansiYellow": "#92400E",
    "terminal.ansiBlue": "#2563EB",
    "terminal.ansiMagenta": "#7C3AED",
    "terminal.ansiCyan": "#1E40AF",
    "terminal.ansiWhite": "#2D2B55",
    "terminal.ansiBrightBlack": "#7B7A9E",
    "terminal.ansiBrightRed": "#BE185D",
    "terminal.ansiBrightGreen": "#3D6B3D",
    "terminal.ansiBrightYellow": "#92400E",
    "terminal.ansiBrightBlue": "#2563EB",
    "terminal.ansiBrightMagenta": "#7C3AED",
    "terminal.ansiBrightCyan": "#1E40AF",
    "terminal.ansiBrightWhite": "#2D2B55",
    "input.background": "#EDE8F8",
    "input.foreground": "#2D2B55",
    "input.border": "#D4CCF0",
    "focusBorder": "#2563EB",
    "selection.background": "#2563EB40",
    "list.activeSelectionBackground": "#EDE8F8",
    "list.activeSelectionForeground": "#2D2B55",
    "list.hoverBackground": "#EDE8F880",
    "list.focusBackground": "#EDE8F8",
    "scrollbarSlider.background": "#7B7A9E50",
    "scrollbarSlider.hoverBackground": "#7B7A9E80",
    "scrollbarSlider.activeBackground": "#7B7A9E",
    "button.background": "#2563EB",
    "button.foreground": "#F5F0FF",
    "badge.background": "#2563EB",
    "badge.foreground": "#F5F0FF",
    "gitDecoration.addedResourceForeground": "#0891B2",
    "gitDecoration.modifiedResourceForeground": "#92400E",
    "gitDecoration.deletedResourceForeground": "#BE185D",
    "gitDecoration.untrackedResourceForeground": "#0891B2",
    "gitDecoration.ignoredResourceForeground": "#7B7A9E",
    "editorError.foreground": "#BE185D",
    "editorWarning.foreground": "#C2410C",
    "editorInfo.foreground": "#0891B2",
    "editorGutter.addedBackground": "#0891B2",
    "editorGutter.modifiedBackground": "#92400E",
    "editorGutter.deletedBackground": "#BE185D"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#3D6B3D",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#7C3AED"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7C3AED"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1E40AF"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#2563EB",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#0891B2"
      }
    },
    {
      "scope": [
        "string.quoted",
        "string.template",
        "string"
      ],
      "settings": {
        "foreground": "#C2410C"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#9c5a0a"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#9c5a0a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#92400E"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#BE185D"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#1a6b8a"
      }
    },
    {
      "scope": [
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#C2410C"
      }
    },
    {
      "scope": [
        "punctuation.bracket",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2563EB"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#7B7A9E"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#2D2B55",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#BE185D",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#BE185D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#0891B2"
      }
    }
  ]
}