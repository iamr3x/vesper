{
  "$schema": "vscode://schemas/color-theme",
  "name": "Vesper Light",
  "type": "light",
  "colors": {
    "editor.background": "#f5f0e8",
    "editor.foreground": "#2c2520",
    "editorLineNumber.foreground": "#b0a898",
    "editorLineNumber.activeForeground": "#8a7a6a",
    "editor.selectionBackground": "#7a500040",
    "editor.inactiveSelectionBackground": "#7a500020",
    "editor.lineHighlightBackground": "#00000008",
    "editorCursor.foreground": "#2c2520",
    "editorWhitespace.foreground": "#8a7a6a50",
    "editorIndentGuide.background1": "#d8d0c0",
    "editorIndentGuide.activeBackground1": "#8a7a6a",
    "editor.findMatchBackground": "#1a787850",
    "editor.findMatchHighlightBackground": "#1a787830",
    "editorBracketMatch.background": "#7a500030",
    "editorBracketMatch.border": "#7a5000",
    "sideBar.background": "#e0dbd0",
    "sideBar.foreground": "#2c2520",
    "sideBar.border": "#d8d0c0",
    "sideBarTitle.foreground": "#8a7a6a",
    "activityBar.background": "#e0dbd0",
    "activityBar.foreground": "#2c2520",
    "activityBar.inactiveForeground": "#8a7a6a",
    "activityBar.border": "#d8d0c0",
    "statusBar.background": "#e0dbd0",
    "statusBar.foreground": "#2c2520",
    "statusBar.border": "#d8d0c0",
    "titleBar.activeBackground": "#e0dbd0",
    "titleBar.activeForeground": "#2c2520",
    "titleBar.border": "#d8d0c0",
    "tab.activeBackground": "#ede8e0",
    "tab.inactiveBackground": "#f5f0e8",
    "tab.activeForeground": "#2c2520",
    "tab.inactiveForeground": "#8a7a6a",
    "tab.border": "#d8d0c0",
    "panel.background": "#e0dbd0",
    "panel.border": "#d8d0c0",
    "terminal.background": "#e0dbd0",
    "terminal.foreground": "#2c2520",
    "terminal.ansiBlack": "#ede8e0",
    "terminal.ansiRed": "#aa3333",
    "terminal.ansiGreen": "#9a9080",
    "terminal.ansiYellow": "#7a44aa",
    "terminal.ansiBlue": "#7a5000",
    "terminal.ansiMagenta": "#9a6600",
    "terminal.ansiCyan": "#606060",
    "terminal.ansiWhite": "#2c2520",
    "terminal.ansiBrightBlack": "#8a7a6a",
    "terminal.ansiBrightRed": "#aa3333",
    "terminal.ansiBrightGreen": "#9a9080",
    "terminal.ansiBrightYellow": "#7a44aa",
    "terminal.ansiBrightBlue": "#7a5000",
    "terminal.ansiBrightMagenta": "#9a6600",
    "terminal.ansiBrightCyan": "#606060",
    "terminal.ansiBrightWhite": "#2c2520",
    "input.background": "#ede8e0",
    "input.foreground": "#2c2520",
    "input.border": "#d8d0c0",
    "focusBorder": "#7a5000",
    "selection.background": "#7a500040",
    "list.activeSelectionBackground": "#ede8e0",
    "list.activeSelectionForeground": "#2c2520",
    "list.hoverBackground": "#ede8e080",
    "list.focusBackground": "#ede8e0",
    "scrollbarSlider.background": "#8a7a6a50",
    "scrollbarSlider.hoverBackground": "#8a7a6a80",
    "scrollbarSlider.activeBackground": "#8a7a6a",
    "button.background": "#7a5000",
    "button.foreground": "#f5f0e8",
    "badge.background": "#7a5000",
    "badge.foreground": "#f5f0e8",
    "gitDecoration.addedResourceForeground": "#1a7878",
    "gitDecoration.modifiedResourceForeground": "#7a44aa",
    "gitDecoration.deletedResourceForeground": "#aa3333",
    "gitDecoration.untrackedResourceForeground": "#1a7878",
    "gitDecoration.ignoredResourceForeground": "#8a7a6a",
    "editorError.foreground": "#aa3333",
    "editorWarning.foreground": "#2d7a2d",
    "editorInfo.foreground": "#1a7878",
    "editorGutter.addedBackground": "#1a7878",
    "editorGutter.modifiedBackground": "#7a44aa",
    "editorGutter.deletedBackground": "#aa3333"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#9a9080",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#9a6600"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9a6600"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#606060"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7a5000",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#1a7878"
      }
    },
    {
      "scope": [
        "string.quoted",
        "string.template",
        "string"
      ],
      "settings": {
        "foreground": "#2d7a2d"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#b85030"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#b85030"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#b86030"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#7a44aa"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#b86030"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#aa3333"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#b86030"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#1a6a8a"
      }
    },
    {
      "scope": [
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#2d7a2d"
      }
    },
    {
      "scope": [
        "punctuation.bracket",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#7a5000"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#8a7a6a"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#2c2520",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#aa3333",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#aa3333",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#1a7878"
      }
    }
  ]
}