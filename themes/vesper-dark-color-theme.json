{
  "$schema": "vscode://schemas/color-theme",
  "name": "Vesper Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#101010",
    "editor.foreground": "#d4c9b0",
    "editorLineNumber.foreground": "#3a3530",
    "editorLineNumber.activeForeground": "#6b6050",
    "editor.selectionBackground": "#e8b86d40",
    "editor.inactiveSelectionBackground": "#e8b86d20",
    "editor.lineHighlightBackground": "#ffffff0d",
    "editorCursor.foreground": "#d4c9b0",
    "editorWhitespace.foreground": "#6b605050",
    "editorIndentGuide.background1": "#1e1c1a",
    "editorIndentGuide.activeBackground1": "#6b6050",
    "editor.findMatchBackground": "#6ec6c650",
    "editor.findMatchHighlightBackground": "#6ec6c630",
    "editorBracketMatch.background": "#e8b86d30",
    "editorBracketMatch.border": "#e8b86d",
    "sideBar.background": "#0c0c0c",
    "sideBar.foreground": "#d4c9b0",
    "sideBar.border": "#1e1c1a",
    "sideBarTitle.foreground": "#6b6050",
    "activityBar.background": "#0c0c0c",
    "activityBar.foreground": "#d4c9b0",
    "activityBar.inactiveForeground": "#6b6050",
    "activityBar.border": "#1e1c1a",
    "statusBar.background": "#0c0c0c",
    "statusBar.foreground": "#d4c9b0",
    "statusBar.border": "#1e1c1a",
    "titleBar.activeBackground": "#0c0c0c",
    "titleBar.activeForeground": "#d4c9b0",
    "titleBar.border": "#1e1c1a",
    "tab.activeBackground": "#181818",
    "tab.inactiveBackground": "#101010",
    "tab.activeForeground": "#d4c9b0",
    "tab.inactiveForeground": "#6b6050",
    "tab.border": "#1e1c1a",
    "panel.background": "#0c0c0c",
    "panel.border": "#1e1c1a",
    "terminal.background": "#0c0c0c",
    "terminal.foreground": "#d4c9b0",
    "terminal.ansiBlack": "#181818",
    "terminal.ansiRed": "#d47070",
    "terminal.ansiGreen": "#5c5445",
    "terminal.ansiYellow": "#b088c8",
    "terminal.ansiBlue": "#e8b86d",
    "terminal.ansiMagenta": "#cc9944",
    "terminal.ansiCyan": "#888888",
    "terminal.ansiWhite": "#d4c9b0",
    "terminal.ansiBrightBlack": "#6b6050",
    "terminal.ansiBrightRed": "#d47070",
    "terminal.ansiBrightGreen": "#5c5445",
    "terminal.ansiBrightYellow": "#b088c8",
    "terminal.ansiBrightBlue": "#e8b86d",
    "terminal.ansiBrightMagenta": "#cc9944",
    "terminal.ansiBrightCyan": "#888888",
    "terminal.ansiBrightWhite": "#d4c9b0",
    "input.background": "#181818",
    "input.foreground": "#d4c9b0",
    "input.border": "#1e1c1a",
    "focusBorder": "#e8b86d",
    "selection.background": "#e8b86d40",
    "list.activeSelectionBackground": "#181818",
    "list.activeSelectionForeground": "#d4c9b0",
    "list.hoverBackground": "#18181880",
    "list.focusBackground": "#181818",
    "scrollbarSlider.background": "#6b605050",
    "scrollbarSlider.hoverBackground": "#6b605080",
    "scrollbarSlider.activeBackground": "#6b6050",
    "button.background": "#e8b86d",
    "button.foreground": "#101010",
    "badge.background": "#e8b86d",
    "badge.foreground": "#101010",
    "gitDecoration.addedResourceForeground": "#6ec6c6",
    "gitDecoration.modifiedResourceForeground": "#b088c8",
    "gitDecoration.deletedResourceForeground": "#d47070",
    "gitDecoration.untrackedResourceForeground": "#6ec6c6",
    "gitDecoration.ignoredResourceForeground": "#6b6050",
    "editorError.foreground": "#d47070",
    "editorWarning.foreground": "#8fbe8f",
    "editorInfo.foreground": "#6ec6c6",
    "editorGutter.addedBackground": "#6ec6c6",
    "editorGutter.modifiedBackground": "#b088c8",
    "editorGutter.deletedBackground": "#d47070"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#5c5445",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#cc9944"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#cc9944"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#e8b86d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#6ec6c6"
      }
    },
    {
      "scope": [
        "string.quoted",
        "string.template",
        "string"
      ],
      "settings": {
        "foreground": "#8fbe8f"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#e07b54"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#e07b54"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#d4956a"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#b088c8"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d4956a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#d47070"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d4956a"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#72b8d0"
      }
    },
    {
      "scope": [
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#8fbe8f"
      }
    },
    {
      "scope": [
        "punctuation.bracket",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#e8b86d"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#6b6050"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#d4c9b0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#d47070",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#d47070",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#6ec6c6"
      }
    }
  ]
}